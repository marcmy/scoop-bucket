{
    "version": "0.7.1",
    "description": "GPU-accelerated mosaic restoration tool with GUI and CLI for modern NVIDIA GPUs.",
    "homepage": "https://github.com/Kruk2/jasna",
    "license": "AGPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": [
                "https://github.com/Kruk2/jasna/releases/download/v0.7.1/jasna-v0.7.1.7z.001",
                "https://github.com/Kruk2/jasna/releases/download/v0.7.1/jasna-v0.7.1.7z.002",
                "https://github.com/Kruk2/jasna/releases/download/v0.7.1/jasna-v0.7.1.7z.003"
            ],
            "hash": [
                "5de7cdd8c28971a968f43508b163c2a889a3d6d246c2b0f5dc0c1ae17ea94251",
                "ecb2cabed5b078a57e657030b1b3beb80ed281b9061592dc756f7e4212568647",
                "a6acc10a614d76973e5c3ea30191cd55ae982de79f7178e1e5d9a7eebe08f009"
            ]
        }
    },
    "pre_install": [
        "$ErrorActionPreference = 'Stop'",
        "$gui = Join-Path $dir 'jasna-gui.exe'",
        "$cli = Join-Path $dir 'jasna-cli.exe'",
        "if (!(Test-Path $gui) -or !(Test-Path $cli)) {",
        "    $nested = Get-ChildItem $dir -Directory | Where-Object { (Test-Path (Join-Path $_.FullName 'jasna-gui.exe')) -and (Test-Path (Join-Path $_.FullName 'jasna-cli.exe')) } | Select-Object -First 1",
        "    if ($nested) {",
        "        Get-ChildItem $nested.FullName -Force | Move-Item -Destination $dir -Force",
        "        Remove-Item $nested.FullName -Recurse -Force -ErrorAction SilentlyContinue",
        "    }",
        "}",
        "if (!(Test-Path $gui)) { throw 'jasna-gui.exe was not found after extraction.' }",
        "if (!(Test-Path $cli)) { throw 'jasna-cli.exe was not found after extraction.' }"
    ],
    "bin": [
        [
            "jasna-gui.exe",
            "jasna"
        ],
        [
            "jasna-gui.exe",
            "jasna-gui"
        ],
        [
            "jasna-cli.exe",
            "jasna-cli"
        ]
    ],
    "shortcuts": [
        [
            "jasna-gui.exe",
            "Jasna"
        ]
    ],
    "persist": "model_weights",
    "notes": [
        "This is a large split 7-Zip release. Scoop extracts the .001 part after all chunks are downloaded and verified.",
        "Jasna requires a modern NVIDIA GPU and current NVIDIA drivers. First run compiles TensorRT engines and can take a while.",
        "model_weights is persisted so compiled engines survive updates.",
        "Jasna settings are stored by the app under $env:APPDATA\\jasna, outside Scoop's install dir, so they are not managed by this manifest.",
        "For Stash integration, use: JASNA_CLI_PATH=$dir\\jasna-cli.exe and JASNA_WORKING_DIR=$dir"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": [
                    "https://github.com/Kruk2/jasna/releases/download/v$version/jasna-v$version.7z.001",
                    "https://github.com/Kruk2/jasna/releases/download/v$version/jasna-v$version.7z.002",
                    "https://github.com/Kruk2/jasna/releases/download/v$version/jasna-v$version.7z.003"
                ],
                "hash": [
                    {
                        "mode": "json",
                        "url": "https://api.github.com/repos/Kruk2/jasna/releases/tags/v$version",
                        "jsonpath": "$..assets[?(@.name=='jasna-v$version.7z.001')].digest",
                        "regex": "sha256:([a-f0-9]{64})"
                    },
                    {
                        "mode": "json",
                        "url": "https://api.github.com/repos/Kruk2/jasna/releases/tags/v$version",
                        "jsonpath": "$..assets[?(@.name=='jasna-v$version.7z.002')].digest",
                        "regex": "sha256:([a-f0-9]{64})"
                    },
                    {
                        "mode": "json",
                        "url": "https://api.github.com/repos/Kruk2/jasna/releases/tags/v$version",
                        "jsonpath": "$..assets[?(@.name=='jasna-v$version.7z.003')].digest",
                        "regex": "sha256:([a-f0-9]{64})"
                    }
                ]
            }
        }
    }
}
