{
    "version": "26354320543",
    "description": "Free and reliable P2P BitTorrent client. Nightly CI build using libtorrent 2.1.0-rc1.",
    "homepage": "https://github.com/qbittorrent/qBittorrent",
    "license": {
        "identifier": "GPL-2.0-only",
        "url": "https://github.com/qbittorrent/qBittorrent/blob/master/COPYING"
    },
    "notes": [
        "This manifest tracks CI artifacts that include libtorrent 2.1.0-rc1.",
        "For file associations, run:",
        "reg import \"$dir\\install-associations.reg\""
    ],
    "suggest": {
        "vcredist": "extras/vcredist2022"
    },
    "architecture": {
        "64bit": {
            "url": "https://nightly.link/qbittorrent/qBittorrent/actions/runs/26354320543/qBittorrent-CI_Windows-x64_libtorrent-2.1.0-rc1.zip",
            "hash": "c2efeda4ddcc38f531b10f1e1b3ab484daa3932aac927503993b50ffc75a7520",
            "extract_dir": "qBittorrent"
        }
    },
    "pre_install": [
        "if (Test-Path \"$dir/qbittorrent.pdb\") { Remove-Item \"$dir/qbittorrent.pdb\" -Force }",
        "if (!(Test-Path \"$persist_dir/profile\")) {",
        "    $source = @(",
        "        \"$persist_dir/../qbittorrent-nightly/profile\",",
        "        \"$persist_dir/../qbittorrent-portable/profile\"",
        "    ) | Where-Object { Test-Path \"$_/qBittorrent\" } | Select-Object -First 1",
        "    if ($source) {",
        "        Write-Host \"Importing existing qBittorrent profile from $source\" -ForegroundColor Yellow",
        "        New-Item \"$persist_dir/profile\" -ItemType Directory -Force | Out-Null",
        "        Copy-Item \"$source/qBittorrent\" \"$persist_dir/profile/qBittorrent\" -Recurse -Force | Out-Null",
        "    } elseif (Test-Path \"$env:APPDATA/qBittorrent\") {",
        "        Write-Host \"Importing existing non-portable qBittorrent profile from AppData\" -ForegroundColor Yellow",
        "        New-Item \"$persist_dir/profile/qBittorrent/config\" -ItemType Directory -Force | Out-Null",
        "        New-Item \"$persist_dir/profile/qBittorrent/data\" -ItemType Directory -Force | Out-Null",
        "        Copy-Item \"$env:APPDATA/qBittorrent\" \"$persist_dir/profile/qBittorrent/config\" -Recurse -Force | Out-Null",
        "        if (Test-Path \"$env:LOCALAPPDATA/qBittorrent\") {",
        "            Copy-Item \"$env:LOCALAPPDATA/qBittorrent\" \"$persist_dir/profile/qBittorrent/data\" -Recurse -Force | Out-Null",
        "        }",
        "    }",
        "}"
    ],
    "post_install": [
        "'install-associations', 'uninstall-associations' | ForEach-Object {",
        "    if (Test-Path \"$bucketsdir\\$bucket\\scripts\\$app\\$_.reg\") {",
        "        $qbitPath = \"$dir\".Replace('\\', '\\\\')",
        "        $content = (Get-Content \"$bucketsdir\\$bucket\\scripts\\$app\\$_.reg\").Replace('$qbit', $qbitPath)",
        "        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }",
        "        Set-Content \"$dir\\$_.reg\" $content -Encoding Ascii -Force",
        "    }",
        "}"
    ],
    "bin": [
        [
            "qbittorrent.exe",
            "qbittorrent-lt21"
        ]
    ],
    "shortcuts": [
        [
            "qbittorrent.exe",
            "qBittorrent (nightly lt 2.1)"
        ]
    ],
    "persist": "profile",
    "uninstaller": {
        "script": "if ($cmd -eq 'uninstall') { reg import \"$dir\\uninstall-associations.reg\" }"
    },
    "checkver": {
        "url": "https://api.github.com/repos/qbittorrent/qBittorrent/actions/artifacts?name=qBittorrent-CI_Windows-x64_libtorrent-2.1.0-rc1&per_page=100",
        "script": [
            "$artifact = (($page | ConvertFrom-Json).artifacts | Where-Object {",
            "    ($_.name -eq 'qBittorrent-CI_Windows-x64_libtorrent-2.1.0-rc1') -and",
            "    (-not $_.expired)",
            "} | Sort-Object created_at -Descending | Select-Object -First 1)",
            "if (-not $artifact) { throw 'No matching non-expired lt21 artifacts found' }",
            "\"{0} {1}\" -f $artifact.workflow_run.id, $artifact.name"
        ],
        "regex": "^(?<version>\\d+) (?<artifact>.+)$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://nightly.link/qbittorrent/qBittorrent/actions/runs/$version/$matchArtifact.zip",
                "hash": {
                    "mode": "json",
                    "url": "https://api.github.com/repos/qbittorrent/qBittorrent/actions/runs/$version/artifacts",
                    "jsonpath": "$..artifacts[?(@.name=='$matchArtifact')].digest"
                }
            }
        }
    }
}
