{
    "version": "21.0.0.1239",
    "description": "Screen capture, file sharing and productivity tool. Portable development build.",
    "homepage": "https://getsharex.com/",
    "license": "GPL-3.0-only",
    "notes": "Tracks portable development builds published to ShareX/DevBuilds.",
    "architecture": {
        "64bit": {
            "url": "https://github.com/ShareX/DevBuilds/releases/download/v21.0.0.1239/ShareX-21.0.0.1239-portable-x64.zip",
            "hash": "5f2dc7c523cc1d803b16408471f765def1ece1b2713984ac0ddb5ef2853818b6"
        }
    },
    "pre_install": "if (!(Test-Path \"$persist_dir\\PersonalPath.cfg\")) { New-Item \"$dir\\PersonalPath.cfg\" | Out-Null }",
    "bin": [
        [
            "ShareX.exe",
            "sharex-dev-portable"
        ]
    ],
    "shortcuts": [
        [
            "ShareX.exe",
            "ShareX Dev Portable"
        ]
    ],
    "persist": [
        "PersonalPath.cfg",
        "ShareX"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/ShareX/DevBuilds/releases?per_page=100",
        "script": [
            "$release = @($page | ConvertFrom-Json) | Where-Object {",
            "    if ($_.draft -or $_.tag_name -notmatch '^v\\d+(?:\\.\\d+){3}$') { return $false }",
            "    $version = $_.tag_name.TrimStart('v')",
            "    $_.assets.name -contains \"ShareX-$version-portable-x64.zip\"",
            "} | Sort-Object { [version]($_.tag_name.TrimStart('v')) } -Descending | Select-Object -First 1",
            "if (-not $release) { throw 'No complete ShareX dev portable release found' }",
            "$release.tag_name.TrimStart('v')"
        ],
        "regex": "^(?<version>\\d+(?:\\.\\d+){3})$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ShareX/DevBuilds/releases/download/v$version/ShareX-$version-portable-x64.zip"
            }
        }
    }
}
