{
    "version": "20.2.0.1140",
    "description": "Screen capture, file sharing and productivity tool. Portable development build.",
    "homepage": "https://getsharex.com/",
    "license": "GPL-3.0-only",
    "notes": [
        "Tracks portable development builds published to ShareX/DevBuilds.",
        "Use sharex-dev-portable-update to update while ShareX is running; it will stop and restart this package's ShareX instance automatically."
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/ShareX/DevBuilds/releases/download/v20.2.0.1140/ShareX-20.2.0.1140-portable-x64.zip",
            "hash": "bfe828ceee34a1747268aa62ccab83118f6858a130adde0b72e3e269932882f4"
        }
    },
    "pre_install": [
        "$updater = @'",
        "param([Parameter(ValueFromRemainingArguments = $true)][string[]]$ScoopArgs)",
        "$ErrorActionPreference = 'Stop'",
        "$app = 'sharex-dev-portable'",
        "$prefix = (& scoop prefix $app | Select-Object -Last 1).Trim()",
        "$appRoot = Split-Path $prefix",
        "$processes = @(Get-Process ShareX -ErrorAction SilentlyContinue | Where-Object { $_.Path -and $_.Path.StartsWith($appRoot, [StringComparison]::OrdinalIgnoreCase) })",
        "$wasRunning = $processes.Count -gt 0",
        "$exitCode = 0",
        "try {",
        "    if ($wasRunning) {",
        "        $processes | Stop-Process -Force",
        "        $processes | Wait-Process -ErrorAction SilentlyContinue",
        "    }",
        "    & scoop update \"marcmy/$app\" @ScoopArgs",
        "    $exitCode = $LASTEXITCODE",
        "} finally {",
        "    if ($wasRunning) {",
        "        $newPrefix = (& scoop prefix $app | Select-Object -Last 1).Trim()",
        "        $exe = Join-Path $newPrefix 'ShareX.exe'",
        "        if (Test-Path $exe) { Start-Process $exe }",
        "    }",
        "}",
        "exit $exitCode",
        "'@",
        "Set-Content -Path \"$dir\\sharex-dev-portable-update.ps1\" -Value $updater -Encoding utf8",
        "if (!(Test-Path \"$persist_dir\\PersonalPath.cfg\")) { New-Item \"$dir\\PersonalPath.cfg\" | Out-Null }"
    ],
    "bin": [
        [
            "ShareX.exe",
            "sharex-dev-portable"
        ],
        [
            "sharex-dev-portable-update.ps1",
            "sharex-dev-portable-update"
        ]
    ],
    "shortcuts": [
        [
            "ShareX.exe",
            "ShareX Dev Portable"
        ]
    ],
    "persist": [
        "PersonalPath.cfg",
        "ShareX"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/ShareX/DevBuilds/releases?per_page=100",
        "script": [
            "$release = @($page | ConvertFrom-Json) | Where-Object {",
            "    if ($_.draft -or $_.tag_name -notmatch '^v\\d+(?:\\.\\d+){3}$') { return $false }",
            "    $version = $_.tag_name.TrimStart('v')",
            "    $_.assets.name -contains \"ShareX-$version-portable-x64.zip\"",
            "} | Sort-Object { [version]($_.tag_name.TrimStart('v')) } -Descending | Select-Object -First 1",
            "if (-not $release) { throw 'No complete ShareX dev portable release found' }",
            "$release.tag_name.TrimStart('v')"
        ],
        "regex": "^(?<version>\\d+(?:\\.\\d+){3})$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ShareX/DevBuilds/releases/download/v$version/ShareX-$version-portable-x64.zip"
            }
        }
    }
}
