{
    "version": "21.0.0.1301",
    "description": "Screen capture, file sharing and productivity tool. Development build using the native installer.",
    "homepage": "https://getsharex.com/",
    "license": "GPL-3.0-only",
    "notes": "Tracks installer builds published to ShareX/DevBuilds.",
    "architecture": {
        "64bit": {
            "url": "https://github.com/ShareX/DevBuilds/releases/download/v21.0.0.1301/ShareX-21.0.0.1301-setup-x64.exe",
            "hash": "52854fda4f2e672060103eef8ea68ede883b1e0e663ade4d705a6c0b8c535f29"
        }
    },
    "installer": {
        "args": [
            "/VERYSILENT",
            "/SUPPRESSMSGBOXES",
            "/NORESTART",
            "/SP-",
            "/NORUN",
            "/NOICONS",
            "/TASKS=",
            "/DIR=\"$dir\""
        ]
    },
    "post_install": [
        "$programs = [Environment]::GetFolderPath('Programs')",
        "$nativeGroup = Join-Path $programs 'ShareX'",
        "$appRoot = Split-Path $dir",
        "if (Test-Path -LiteralPath $nativeGroup) {",
        "    $shell = New-Object -ComObject WScript.Shell",
        "    Get-ChildItem -LiteralPath $nativeGroup -Filter '*.lnk' -File -ErrorAction SilentlyContinue | ForEach-Object {",
        "        try {",
        "            $target = $shell.CreateShortcut($_.FullName).TargetPath",
        "            if ($target -and $target.StartsWith($appRoot, [StringComparison]::OrdinalIgnoreCase)) {",
        "                Remove-Item -LiteralPath $_.FullName -Force",
        "            }",
        "        } catch {}",
        "    }",
        "    if (!(Get-ChildItem -LiteralPath $nativeGroup -Force -ErrorAction SilentlyContinue)) {",
        "        Remove-Item -LiteralPath $nativeGroup -Force",
        "    }",
        "}"
    ],
    "uninstaller": {
        "file": "unins000.exe",
        "args": [
            "/VERYSILENT",
            "/SUPPRESSMSGBOXES",
            "/NORESTART"
        ]
    },
    "bin": [
        [
            "ShareX.exe",
            "sharex-dev"
        ]
    ],
    "shortcuts": [
        [
            "ShareX.exe",
            "ShareX Dev"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/ShareX/DevBuilds/releases?per_page=100",
        "script": [
            "$release = @($page | ConvertFrom-Json) | Where-Object {",
            "    if ($_.draft -or $_.tag_name -notmatch '^v\\d+(?:\\.\\d+){3}$') { return $false }",
            "    $version = $_.tag_name.TrimStart('v')",
            "    $_.assets.name -contains \"ShareX-$version-setup-x64.exe\"",
            "} | Sort-Object { [version]($_.tag_name.TrimStart('v')) } -Descending | Select-Object -First 1",
            "if (-not $release) { throw 'No complete ShareX dev installer release found' }",
            "$release.tag_name.TrimStart('v')"
        ],
        "regex": "^(?<version>\\d+(?:\\.\\d+){3})$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ShareX/DevBuilds/releases/download/v$version/ShareX-$version-setup-x64.exe"
            }
        }
    }
}
