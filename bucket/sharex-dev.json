{
    "version": "20.2.0.1140",
    "description": "Screen capture, file sharing and productivity tool. Development build using the native installer.",
    "homepage": "https://getsharex.com/",
    "license": "GPL-3.0-only",
    "notes": [
        "Tracks installer builds published to ShareX/DevBuilds."
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/ShareX/DevBuilds/releases/download/v20.2.0.1140/ShareX-20.2.0.1140-setup-x64.exe",
            "hash": "658221a224376cad5d9fab2fb4faaec121f688c80cceed49a9c17901ab0eba59"
        }
    },
    "installer": {
        "args": [
            "/VERYSILENT",
            "/SUPPRESSMSGBOXES",
            "/NORESTART",
            "/SP-",
            "/NORUN",
            "/TASKS=",
            "/DIR=\"$dir\""
        ]
    },
    "uninstaller": {
        "file": "unins000.exe",
        "args": [
            "/VERYSILENT",
            "/SUPPRESSMSGBOXES",
            "/NORESTART"
        ]
    },
    "bin": [
        [
            "ShareX.exe",
            "sharex-dev"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/ShareX/DevBuilds/releases?per_page=100",
        "script": [
            "$release = @($page | ConvertFrom-Json) | Where-Object {",
            "    if ($_.draft -or $_.tag_name -notmatch '^v\\d+(?:\\.\\d+){3}$') { return $false }",
            "    $version = $_.tag_name.TrimStart('v')",
            "    $_.assets.name -contains \"ShareX-$version-setup-x64.exe\"",
            "} | Sort-Object { [version]($_.tag_name.TrimStart('v')) } -Descending | Select-Object -First 1",
            "if (-not $release) { throw 'No complete ShareX dev installer release found' }",
            "$release.tag_name.TrimStart('v')"
        ],
        "regex": "^(?<version>\\d+(?:\\.\\d+){3})$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ShareX/DevBuilds/releases/download/v$version/ShareX-$version-setup-x64.exe"
            }
        }
    }
}
