{
    "version": "20.2.0.1139",
    "description": "Screen capture, file sharing and productivity tool. Development build.",
    "homepage": "https://getsharex.com/",
    "license": "GPL-3.0-only",
    "notes": "Tracks development builds published to ShareX/DevBuilds and installs the non-portable setup build.",
    "architecture": {
        "64bit": {
            "url": "https://github.com/ShareX/DevBuilds/releases/download/v20.2.0.1139/ShareX-20.2.0.1139-setup-x64.exe",
            "hash": "c2d99e6fb55831562dd3e368fd33c4473d217f2f7b146d88075bd974d4a501be"
        }
    },
    "installer": {
        "args": [
            "/VERYSILENT",
            "/SUPPRESSMSGBOXES",
            "/NORESTART",
            "/SP-",
            "/DIR=\"$dir\""
        ]
    },
    "uninstaller": {
        "file": "unins000.exe",
        "args": [
            "/VERYSILENT",
            "/SUPPRESSMSGBOXES",
            "/NORESTART"
        ]
    },
    "bin": [
        [
            "ShareX.exe",
            "sharex-dev"
        ]
    ],
    "shortcuts": [
        [
            "ShareX.exe",
            "ShareX Dev"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/ShareX/DevBuilds/releases?per_page=100",
        "script": [
            "$release = @($page | ConvertFrom-Json) | Where-Object {",
            "    if ($_.draft -or $_.tag_name -notmatch '^v\\d+(?:\\.\\d+){3}$') { return $false }",
            "    $version = $_.tag_name.TrimStart('v')",
            "    $_.assets.name -contains \"ShareX-$version-setup-x64.exe\"",
            "} | Sort-Object { [version]($_.tag_name.TrimStart('v')) } -Descending | Select-Object -First 1",
            "if (-not $release) { throw 'No complete ShareX dev release found' }",
            "$release.tag_name.TrimStart('v')"
        ],
        "regex": "^(?<version>\\d+(?:\\.\\d+){3})$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ShareX/DevBuilds/releases/download/v$version/ShareX-$version-setup-x64.exe"
            }
        }
    }
}
