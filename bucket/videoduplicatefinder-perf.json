{
    "homepage": "https://github.com/marcmy/videoduplicatefinder",
    "description": "Video Duplicate Finder GUI, CLI, and Web UI from Marc's perf/native-hwaccel fork build",
    "version": "4.0.0-perf-git-20260612-0643",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/marcmy/videoduplicatefinder/releases/download/4.0.x/Bundle-win-x64.zip",
            "hash": "0bce2e9de6aa90c2a393827ca929462e74e820cda89fbd3224d60abda4292c7f",
            "extract_dir": "Bundle-win-x64"
        }
    },
    "shortcuts": [
        [
            "VDF.GUI.exe",
            "Video Duplicate Finder (Perf)"
        ],
        [
            "VDF.Web.exe",
            "Video Duplicate Finder (Web Perf)"
        ]
    ],
    "bin": [
        [
            "VDF.GUI.exe",
            "vdf-gui-perf"
        ],
        [
            "vdf-cli.exe",
            "vdf-cli-perf"
        ],
        [
            "VDF.Web.exe",
            "vdf-web-perf"
        ]
    ],
    "notes": [
        "This fork release tag is always 4.0.x and the asset is replaced in-place.",
        "Includes GUI, CLI, and Web UI. Use `vdf-gui-perf`, `vdf-cli-perf`, or `vdf-web-perf`.",
        "VDF state files are mirrored from existing installs only when real files exist; missing files do not create placeholders or delete persisted state."
    ],
    "pre_install": [
        "$stateFiles = @('web-settings.json', 'web-credentials.json', 'Settings.json', 'BlacklistedGroups.json', 'ScannedFiles.db', 'ScannedFiles.db-wal', 'ScannedFiles.db-shm', 'backup.scanresults', 'log.txt')",
        "$appRoot = Split-Path $dir -Parent",
        "$newDir = [IO.Path]::GetFullPath($dir)",
        "$candidateDirs = @()",
        "if (Test-Path $appRoot -PathType Container) {",
        "    $candidateDirs += Get-ChildItem -LiteralPath $appRoot -Directory -ErrorAction SilentlyContinue | Where-Object { $_.Name -ne 'current' -and ([IO.Path]::GetFullPath($_.FullName) -ne $newDir) } | Sort-Object LastWriteTimeUtc -Descending",
        "}",
        "$currentDir = Join-Path $appRoot 'current'",
        "if (Test-Path $currentDir -PathType Container) { $candidateDirs += Get-Item -LiteralPath $currentDir }",
        "foreach ($name in $stateFiles) {",
        "    $dst = Join-Path $persist_dir $name",
        "    if (Test-Path $dst -PathType Leaf) { continue }",
        "    foreach ($candidateDir in $candidateDirs) {",
        "        $src = Join-Path $candidateDir.FullName $name",
        "        if (Test-Path $src -PathType Leaf) {",
        "            if (!(Test-Path $persist_dir)) { New-Item -ItemType Directory -Force -Path $persist_dir | Out-Null }",
        "            Copy-Item -Force -LiteralPath $src -Destination $dst",
        "            break",
        "        }",
        "    }",
        "}"
    ],
    "pre_uninstall": [
        "$stateFiles = @('web-settings.json', 'web-credentials.json', 'Settings.json', 'BlacklistedGroups.json', 'ScannedFiles.db', 'ScannedFiles.db-wal', 'ScannedFiles.db-shm', 'backup.scanresults', 'log.txt')",
        "foreach ($name in $stateFiles) {",
        "    $src = Join-Path $dir $name",
        "    $dst = Join-Path $persist_dir $name",
        "    if (Test-Path $src -PathType Leaf) {",
        "        if (!(Test-Path $persist_dir)) { New-Item -ItemType Directory -Force -Path $persist_dir | Out-Null }",
        "        Copy-Item -Force -LiteralPath $src -Destination $dst",
        "    }",
        "}"
    ],
    "post_install": [
        "$stateFiles = @('web-settings.json', 'web-credentials.json', 'Settings.json', 'BlacklistedGroups.json', 'ScannedFiles.db', 'ScannedFiles.db-wal', 'ScannedFiles.db-shm', 'backup.scanresults', 'log.txt')",
        "foreach ($name in $stateFiles) {",
        "    $persisted = Join-Path $persist_dir $name",
        "    $target = Join-Path $dir $name",
        "    if (Test-Path $persisted -PathType Leaf) {",
        "        Copy-Item -Force -LiteralPath $persisted -Destination $target",
        "    } elseif (Test-Path $target -PathType Leaf) {",
        "        if (!(Test-Path $persist_dir)) { New-Item -ItemType Directory -Force -Path $persist_dir | Out-Null }",
        "        Copy-Item -Force -LiteralPath $target -Destination $persisted",
        "    }",
        "}"
    ],
    "checkver": {
        "script": [
            "$ErrorActionPreference='Stop'",
            "$h=@{ 'User-Agent'='Scoop-Checkver'; 'Accept'='application/vnd.github+json'; 'Authorization'=(\"Bearer {0}\" -f $env:GITHUB_TOKEN); 'X-GitHub-Api-Version'='2022-11-28' }",
            "$r=Invoke-RestMethod -Headers $h -Uri 'https://api.github.com/repos/marcmy/videoduplicatefinder/releases/tags/4.0.x'",
            "if ([string]$r.body -notmatch 'Last build based on\\s+([0-9a-fA-F]{7,40})') { throw 'Could not find commit in release body.' }",
            "$Matches[1].Substring(0,7).ToLowerInvariant()"
        ],
        "regex": "^([0-9a-f]{7})$",
        "replace": "4.0.0-perf-git-$1"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/marcmy/videoduplicatefinder/releases/download/4.0.x/Bundle-win-x64.zip",
                "extract_dir": "Bundle-win-x64"
            }
        }
    }
}
