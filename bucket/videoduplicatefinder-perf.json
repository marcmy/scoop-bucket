        ]
    ],
    "persist": [
        "web-settings.json",
        "web-credentials.json",
        "Settings.json",
        "BlacklistedGroups.json",
        "ScannedFiles.db",
        "ScannedFiles.db-wal",
        "ScannedFiles.db-shm",
