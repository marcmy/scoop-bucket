{
    "homepage": "https://github.com/marcmy/FFmpeg-Builds",
    "description": "Hourly FFmpeg master win64 GPLv3 shared build from Marc's FFmpeg-Builds fork",
    "version": "20260721.035242",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/marcmy/FFmpeg-Builds/releases/download/ffmpeg-20260721.035242-win64-marc-shared/ffmpeg-20260721.035242-win64-marc-shared.zip",
            "hash": "6ed84eaac991d56a957eb96b7b7cc3977fee6e75c416a2817d39cf2d382011a2"
        }
    },
    "pre_install": [
        "$root = Get-ChildItem -LiteralPath $dir -Directory -ErrorAction SilentlyContinue | Where-Object { $_.Name -like 'ffmpeg-*' } | Select-Object -First 1",
        "if ($root) {",
        "    Get-ChildItem -LiteralPath $root.FullName -Force | Move-Item -Destination $dir -Force",
        "    Remove-Item -LiteralPath $root.FullName -Recurse -Force",
        "}"
    ],
    "bin": [
        "bin\\ffmpeg.exe",
        "bin\\ffprobe.exe",
        "bin\\ffplay.exe"
    ],
    "notes": [
        "Installs Marc's hourly FFmpeg master GPLv3 shared build.",
        "Provides the regular ffmpeg, ffprobe, and ffplay shims. This will conflict with another Scoop package that also owns those shims."
    ],
    "checkver": {
        "url": "https://api.github.com/repos/marcmy/FFmpeg-Builds/releases?per_page=50",
        "script": [
            "$releases=$page | ConvertFrom-Json",
            "$release=$releases | Where-Object { $_.tag_name -match '^ffmpeg-[0-9]{8}\\.[0-9]{6}-win64-marc-shared$' } | Select-Object -First 1",
            "if ($null -eq $release) { 'ffmpeg-00000000.000000-win64-marc-shared' } else { $release.tag_name }"
        ],
        "regex": "^ffmpeg-([0-9]{8}\\.[0-9]{6})-win64-marc-shared$",
        "replace": "$1"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/marcmy/FFmpeg-Builds/releases/download/ffmpeg-$version-win64-marc-shared/ffmpeg-$version-win64-marc-shared.zip"
            }
        }
    }
}
