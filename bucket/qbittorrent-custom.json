{
    "version": "29636981769",
    "description": "Custom qBittorrent build paired with marcmy/libtorrent custom/qbittorrent-2.1.",
    "homepage": "https://github.com/marcmy/qBittorrent",
    "license": {
        "identifier": "GPL-2.0-only",
        "url": "https://github.com/marcmy/qBittorrent/blob/custom/master/COPYING"
    },
    "notes": [
        "Tracks successful marcmy/qBittorrent custom/master CI artifacts built against marcmy/libtorrent custom/qbittorrent-2.1.",
        "Uses its own isolated persisted profile and never imports another qBittorrent profile automatically.",
        "Existing qbittorrent-custom profile data is preserved across updates.",
        "For file associations, run:",
        "reg import \"$dir\\install-associations.reg\""
    ],
    "suggest": {
        "vcredist": "extras/vcredist2022"
    },
    "architecture": {
        "64bit": {
            "url": "https://nightly.link/marcmy/qBittorrent/actions/runs/29636981769/qBittorrent-Custom_Windows-x64_libtorrent-custom-qbittorrent-2.1-85e9dac7a4d3.zip",
            "hash": "f870eb6450967f80a761cdf0b29a7b09920539f416b641ed322f5f32fdfb6d85",
            "extract_dir": "qBittorrent"
        }
    },
    "pre_install": "if (Test-Path \"$dir/qbittorrent.pdb\") { Remove-Item \"$dir/qbittorrent.pdb\" -Force }",
    "post_install": [
        "'install-associations', 'uninstall-associations' | ForEach-Object {",
        "    if (Test-Path \"$bucketsdir\\$bucket\\scripts\\$app\\$_.reg\") {",
        "        $qbitPath = \"$dir\".Replace('\\', '\\\\')",
        "        $content = (Get-Content \"$bucketsdir\\$bucket\\scripts\\$app\\$_.reg\").Replace('$qbit', $qbitPath)",
        "        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }",
        "        Set-Content \"$dir\\$_.reg\" $content -Encoding Ascii -Force",
        "    }",
        "}"
    ],
    "bin": [
        [
            "qbittorrent.exe",
            "qbittorrent-custom"
        ]
    ],
    "shortcuts": [
        [
            "qbittorrent.exe",
            "qBittorrent custom"
        ]
    ],
    "persist": "profile",
    "uninstaller": {
        "script": "if ($cmd -eq 'uninstall') { reg import \"$dir\\uninstall-associations.reg\" }"
    },
    "checkver": {
        "url": "https://api.github.com/repos/marcmy/qBittorrent/actions/artifacts?per_page=100",
        "script": [
            "$repoId = 1291473014",
            "$namePattern = '^qBittorrent-Custom_Windows-x64_libtorrent-custom-qbittorrent-2\\.1-[0-9a-f]{12}$'",
            "$response = $page | ConvertFrom-Json",
            "$artifact = ($response.artifacts | Where-Object {",
            "    ($_.name -match $namePattern) -and",
            "    (-not $_.expired) -and",
            "    ($_.workflow_run.head_repository_id -eq $repoId) -and",
            "    ($_.workflow_run.head_branch -eq 'custom/master')",
            "} | Sort-Object created_at -Descending | Select-Object -First 1)",
            "if (-not $artifact) { throw 'No matching non-expired marcmy/qBittorrent custom/master artifacts found' }",
            "\"{0} {1}\" -f $artifact.workflow_run.id, $artifact.name"
        ],
        "regex": "^(?<version>\\d+) (?<artifact>.+)$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://nightly.link/marcmy/qBittorrent/actions/runs/$version/$matchArtifact.zip"
            }
        }
    }
}
