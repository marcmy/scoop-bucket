        },
        "32bit": {
            "url": "https://github.com/ec-/Quake3e/releases/download/latest/quake3e-windows-mingw-x86.zip",
            "hash": "a24bb59c6ff9f72098403e82f42b7640801e9d93c64d7b893dfbc1ebc5ada4c0",
