{
    "version": "2026.03.17",
    "description": "USB mouse and controller polling rate overclocking utility for Windows.",
    "homepage": "https://github.com/LordOfMice/hidusbf",
    "license": {
        "identifier": "Unknown",
        "url": "https://github.com/LordOfMice/hidusbf"
    },
    "url": "https://raw.githubusercontent.com/LordOfMice/hidusbf/master/hidusbf.zip",
    "hash": "bd8d1fb0545d8df88d9cef0c67682daef7d304561bc64acfee5c0d8c12d0f797",
    "persist": "install_path.txt",
    "notes": [
        "On first install, Scoop will ask for the folder where a managed HIDUSBF copy should be created.",
        "The installer creates a Desktop shortcut to DRIVER\\Setup.exe inside that managed HIDUSBF folder.",
        "Recent Windows versions may require disabling Memory Integrity before the driver can be installed."
    ],
    "checkver": {
        "url": "https://api.github.com/repos/LordOfMice/hidusbf/commits?path=hidusbf.zip&sha=master&per_page=1",
        "jsonpath": "$[0].commit.committer.date",
        "regex": "^(\\d{4})-(\\d{2})-(\\d{2})T",
        "replace": "$1.$2.$3"
    },
    "autoupdate": {
        "url": "https://raw.githubusercontent.com/LordOfMice/hidusbf/master/hidusbf.zip"
    },
    "pre_install": [
        "$ErrorActionPreference = 'Stop'",
        "$cfg = Join-Path $dir 'install_path.txt'",
        "if (Test-Path $cfg -PathType Container) { Remove-Item $cfg -Recurse -Force }",
        "if (!(Test-Path $cfg -PathType Leaf)) { New-Item -ItemType File -Path $cfg -Force | Out-Null }"
    ],
    "post_install": [
        "$ErrorActionPreference = 'Stop'",
        "if (!(Test-Path $persist_dir)) { New-Item -ItemType Directory -Path $persist_dir | Out-Null }",
        "$cfg = Join-Path $persist_dir 'install_path.txt'",
        "if (Test-Path $cfg -PathType Container) { Remove-Item $cfg -Recurse -Force; New-Item -ItemType File -Path $cfg -Force | Out-Null }",
        "$target = $null",
        "if (Test-Path $cfg) { $target = ([string](Get-Content $cfg -Raw)).Trim() }",
        "if (-not $target) {",
        "  $targetRoot = Read-Host 'Enter the folder where Scoop should create the HIDUSBF copy'",
        "  if ($targetRoot) {",
        "    if (!(Test-Path $targetRoot)) { New-Item -ItemType Directory -Force -Path $targetRoot | Out-Null }",
        "    $target = Join-Path $targetRoot 'HIDUSBF'",
        "    Set-Content -Path $cfg -Value $target -NoNewline",
        "  }",
        "}",
        "if (-not $target) {",
        "  Write-Host 'No install path was provided. Skipping external copy and Desktop shortcut creation.' -ForegroundColor Yellow",
        "  return",
        "}",
        "if (!(Test-Path $target)) { New-Item -ItemType Directory -Force -Path $target | Out-Null }",
        "Get-ChildItem -LiteralPath $dir -Force | Where-Object { $_.Name -ne 'install_path.txt' } | ForEach-Object {",
        "  $destination = Join-Path $target $_.Name",
        "  if ($_.PSIsContainer) { Copy-Item $_.FullName -Destination $destination -Recurse -Force }",
        "  else { Copy-Item $_.FullName -Destination $destination -Force }",
        "}",
        "$marker = Join-Path $target '.scoop-managed'",
        "Set-Content -Path $marker -Value 'hidusbf' -NoNewline",
        "$setup = Join-Path $target 'DRIVER\\Setup.exe'",
        "if (Test-Path $setup) {",
        "  $desktop = [Environment]::GetFolderPath('Desktop')",
        "  $shortcutPath = Join-Path $desktop 'HIDUSBF Setup.lnk'",
        "  $shell = New-Object -ComObject WScript.Shell",
        "  $shortcut = $shell.CreateShortcut($shortcutPath)",
        "  $shortcut.TargetPath = $setup",
        "  $shortcut.WorkingDirectory = Split-Path $setup",
        "  $shortcut.IconLocation = $setup",
        "  $shortcut.Save()",
        "  Write-Host ('Copied HIDUSBF to: {0}' -f $target) -ForegroundColor Green",
        "  Write-Host ('Created Desktop shortcut: {0}' -f $shortcutPath) -ForegroundColor Green",
        "} else {",
        "  Write-Host ('Expected Setup.exe was not found at: {0}' -f $setup) -ForegroundColor Yellow",
        "}"
    ],
    "pre_uninstall": [
        "$cfg = Join-Path $persist_dir 'install_path.txt'",
        "if (Test-Path $cfg -PathType Leaf) {",
        "  $target = ([string](Get-Content $cfg -Raw)).Trim()",
        "  if ($target) {",
        "    $marker = Join-Path $target '.scoop-managed'",
        "    if ((Test-Path $target) -and (Test-Path $marker)) {",
        "      Get-ChildItem -LiteralPath $dir -Force | Where-Object { $_.Name -ne 'install_path.txt' } | ForEach-Object {",
        "      $destination = Join-Path $target $_.Name",
        "      if (Test-Path $destination) { Remove-Item $destination -Recurse -Force }",
        "    }",
        "    if (Test-Path $marker) { Remove-Item $marker -Force }",
        "    if ((Test-Path $target) -and -not (Get-ChildItem -LiteralPath $target -Force | Select-Object -First 1)) { Remove-Item $target -Force }",
        "  }",
        "  }",
        "}",
        "$desktop = [Environment]::GetFolderPath('Desktop')",
        "$shortcutPath = Join-Path $desktop 'HIDUSBF Setup.lnk'",
        "if (Test-Path $shortcutPath) { Remove-Item $shortcutPath -Force }"
    ]
}
